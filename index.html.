<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>MUGZ</title>
<link href="https://fonts.googleapis.com/css2?family=Permanent+Marker&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet"/>
<style>
  :root {
    --black: #0d0d0d;
    --red:   #cc1111;
    --white: #f0ece4;
    --off:   #e8e4dc;
    --dim:   #888;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    min-height: 100vh;
    background: var(--off);
    color: var(--black);
    font-family: 'Space Mono', monospace;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow-x: hidden;
    padding: 40px 20px;
  }

  body::before {
    content: '';
    position: fixed; inset: 0;
    background: repeating-linear-gradient(
      180deg, transparent 0px, transparent 54px,
      rgba(0,0,0,0.1) 54px, rgba(0,0,0,0.1) 58px
    );
    pointer-events: none; z-index: 0;
  }

  .stage {
    position: relative; z-index: 1;
    width: 100%; max-width: 480px;
    display: flex; flex-direction: column;
    align-items: center; gap: 0;
  }

  /* PFP */
  .pfp {
    width: 90px; height: 90px;
    border-radius: 50%;
    border: 3px solid var(--black);
    object-fit: cover;
    box-shadow: 4px 4px 0 var(--red);
    margin-bottom: 20px;
  }

  /* Main card */
  .card {
    width: 100%;
    background: var(--white);
    border: 2px solid var(--black);
    border-top: 4px solid var(--red);
    padding: 28px 24px;
    box-shadow: 5px 5px 0 var(--black);
  }

  .eyebrow {
    font-size: 9px;
    letter-spacing: 4px;
    color: var(--dim);
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .headline {
    font-family: 'Permanent Marker', cursive;
    font-size: 22px;
    line-height: 1.3;
    color: var(--black);
    margin-bottom: 16px;
  }

  .headline span { color: var(--red); }

  .body-text {
    font-size: 11px;
    line-height: 1.8;
    color: var(--dim);
    letter-spacing: 1px;
    margin-bottom: 28px;
    padding-bottom: 20px;
    border-bottom: 1px solid #ddd;
  }

  /* Tweet preview box */
  .tweet-box {
    background: var(--off);
    border: 2px solid var(--black);
    padding: 14px 16px;
    font-size: 11px;
    line-height: 1.7;
    color: var(--black);
    margin-bottom: 20px;
    position: relative;
  }
  .tweet-box::before {
    content: '𝕏';
    position: absolute;
    top: 10px; right: 12px;
    font-size: 16px;
    color: var(--dim);
  }
  .tweet-box em {
    color: var(--red);
    font-style: normal;
  }

  /* Buttons */
  .btn-tweet {
    width: 100%;
    background: var(--black);
    color: var(--white);
    border: 2px solid var(--black);
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    padding: 14px;
    cursor: pointer;
    text-transform: uppercase;
    box-shadow: 3px 3px 0 var(--red);
    transition: all .15s;
    margin-bottom: 10px;
  }
  .btn-tweet:hover { background: var(--red); border-color: var(--red); box-shadow: 3px 3px 0 var(--black); }

  .btn-wl {
    width: 100%;
    background: transparent;
    color: var(--dim);
    border: 1px solid #ccc;
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    padding: 11px;
    cursor: pointer;
    text-transform: uppercase;
    transition: all .15s;
    text-decoration: none;
    display: block;
    text-align: center;
  }
  .btn-wl:hover { color: var(--black); border-color: var(--black); }

  /* Form (hidden initially) */
  .wl-form {
    display: none;
    width: 100%;
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid #ddd;
  }
  .wl-form.show { display: block; }

  .input-label {
    font-size: 9px; letter-spacing: 3px; color: var(--dim);
    text-transform: uppercase; display: block; margin-bottom: 8px;
  }
  .input-field {
    width: 100%; background: var(--off);
    border: 2px solid var(--black);
    color: var(--black); font-family: 'Space Mono', monospace;
    font-size: 12px; padding: 12px 14px; outline: none;
    margin-bottom: 16px; transition: border-color .2s;
  }
  .input-field:focus { border-color: var(--red); }
  .input-field::placeholder { color: #aaa; }

  .error-msg { font-size: 10px; color: var(--red); margin-top: -12px; margin-bottom: 12px; display: none; }
  .error-msg.show { display: block; }

  .btn-submit {
    width: 100%;
    background: var(--red);
    color: var(--white);
    border: 2px solid var(--black);
    font-family: 'Space Mono', monospace;
    font-size: 11px; font-weight: 700;
    letter-spacing: 3px; padding: 14px;
    cursor: pointer; text-transform: uppercase;
    box-shadow: 3px 3px 0 var(--black);
    transition: all .15s;
  }
  .btn-submit:hover { background: #ff2222; }
  .btn-submit:disabled { opacity: .4; cursor: not-allowed; }

  /* Success */
  .success {
    display: none;
    text-align: center;
    padding: 20px 0 0;
    border-top: 1px solid #ddd;
    margin-top: 20px;
  }
  .success.show { display: block; }
  .success-stamp {
    font-family: 'Permanent Marker', cursive;
    font-size: 36px;
    color: var(--red);
    border: 3px solid var(--red);
    display: inline-block;
    padding: 4px 16px;
    transform: rotate(-3deg);
    margin-bottom: 10px;
    animation: pop .4s cubic-bezier(.36,2,.6,1) both;
  }
  @keyframes pop { from { transform: scale(0.2) rotate(-3deg); opacity:0; } to { transform: scale(1) rotate(-3deg); opacity:1; } }
  .success-sub { font-size: 9px; letter-spacing: 3px; color: var(--dim); text-transform: uppercase; }

  .booking-ref { font-size: 9px; letter-spacing: 3px; color: #bbb; text-align: center; margin-top: 20px; text-transform: uppercase; }
  .x-handle {
    position: fixed; top: 16px; right: 16px; z-index: 10;
    font-size: 10px; letter-spacing: 2px; color: var(--dim);
    text-decoration: none; text-transform: uppercase;
    border: 1px solid #ccc; padding: 5px 10px;
    background: var(--white); transition: all .15s;
  }
  .x-handle:hover { border-color: var(--black); color: var(--black); }
</style>
</head>
<body>
<a class="x-handle" href="https://x.com/mugzoneth" target="_blank">@mugzoneth</a>
<div class="stage">

  <img class="pfp" src="data:image/jpeg;base64," alt="MUGZ"/>

  <div class="card">
    <div class="eyebrow">Heads up</div>
    <div class="headline">You might be interested in getting a <span>MUGZ</span> WL</div>
    <div class="body-text">
      Low IQ characters<br/>
      Tweet, drop your wallet, move on
    </div>

    <!-- Tweet preview -->
    <div class="tweet-box">
      I just followed <em>@mugzoneth</em>, nothing much but they look like some low iq characters coming on opensea
      you can try to grab wl here if you like - <em>mugz.wtf</em>
    </div>

    <button class="btn-tweet" onclick="doTweet()">Post This Tweet →</button>

    <!-- Form after tweet -->
    <div class="wl-form" id="wl-form">
      <label class="input-label">Your tweet link</label>
      <input class="input-field" id="tweet-link" type="url" placeholder="https://x.com/..."/>
      <div class="error-msg" id="err-tweet">⚠ Paste your tweet link</div>

      <label class="input-label">Wallet address</label>
      <input class="input-field" id="wallet-addr" type="text" placeholder="0x..." spellcheck="false"/>
      <div class="error-msg" id="err-wallet">⚠ Enter a valid 0x address</div>

      <button class="btn-submit" onclick="submitForm()">Submit →</button>
    </div>

    <!-- Success -->
    <div class="success" id="success">
      <div class="success-stamp">BOOKED</div>
      <div class="success-sub" style="margin-top:10px;">Your entry has been recorded</div>
    </div>
  </div>

  <div class="booking-ref">@mugzoneth</div>
</div>

<script>
  const TWEET_TEXT = encodeURIComponent('I just followed @mugzoneth, nothing much but they look like some low iq characters coming on opensea you can try to grab wl here if you like - mugz.wtf');

  function doTweet() {
    window.open('https://x.com/intent/tweet?text=' + TWEET_TEXT, '_blank');
    // Show form when user returns
    document.addEventListener('visibilitychange', function onReturn() {
      if(document.visibilityState === 'visible') {
        document.getElementById('wl-form').classList.add('show');
        document.removeEventListener('visibilitychange', onReturn);
      }
    });
  }

  async function submitForm() {
    const tweetLink = document.getElementById('tweet-link').value.trim();
    const wallet = document.getElementById('wallet-addr').value.trim();
    let valid = true;

    if(!tweetLink.startsWith('http')) {
      document.getElementById('err-tweet').classList.add('show'); valid = false;
    } else { document.getElementById('err-tweet').classList.remove('show'); }

    if(!/^0x[a-fA-F0-9]{40}$/.test(wallet)) {
      document.getElementById('err-wallet').classList.add('show'); valid = false;
    } else { document.getElementById('err-wallet').classList.remove('show'); }

    if(!valid) return;

    const btn = document.querySelector('.btn-submit');
    btn.textContent = 'SUBMITTING...'; btn.disabled = true;

    try {
      await fetch('https://asesfmdbostoxteycdkn.supabase.co/rest/v1/whitelist', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'apikey': 'sb_publishable_feZ8gIajC71LCJ7Wz9c7ig_3yQguV-t',
          'Authorization': 'Bearer sb_publishable_feZ8gIajC71LCJ7Wz9c7ig_3yQguV-t',
          'Prefer': 'return=minimal'
        },
        body: JSON.stringify({
          x_username: 'landing_page',
          wallet: wallet,
          comment_link: tweetLink,
          source: 'mugz.wtf'
        })
      });
    } catch(e) { console.error(e); }

    document.getElementById('wl-form').classList.remove('show');
    document.getElementById('success').classList.add('show');
  }
</script>
</body>
</html>
